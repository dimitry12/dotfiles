{
  "allowPty": true,
  "enableWeakerNetworkIsolation": true,
  "network": {
    "allowedDomains": [],
    "deniedDomains": []
  },
  "filesystem": {
    "denyRead": [
      "/Users"
    ],
    "allowRead": [
      ".",
      "~/.gitconfig",
      "~/.config/git/ignore",
      "~/.local/bin",
      "~/.local/share/uv/python",
      "~/.local/share/uv/tools/dvc",
      "~/.nvm/versions/node/v24.12.0",
      "~/Programs/flutter",
      "~/.pub-cache"
    ],
    "allowWrite": [
      ".",
      "./.pi/mcp-results/"
    ],
    "denyWrite": [
      "/comment protect the file history in case agent wrecks worktree",
      "./.git",
      "./.pi",
      "./.pi/sandbox.json",
      "./.pi/mcp.json",
      "./.pi/mcp-result-spooler.json"
    ]
  }
}
