#!{{ lookPath "bash" }}

# Platform-specific package installation

{{ if eq .chezmoi.os "android" -}}
termux-setup-storage

# Install declared packages
{{ range .packages.termux -}}
pkg install {{ . | quote }}
{{ end -}}

{{ end -}}

{{ if eq .chezmoi.os "darwin" -}}

# Update MacPorts
# sudo port selfupdate

# Install declared packages
{{ range .packages.darwin.macports -}}
sudo port install {{ . | quote }}
{{ end -}}

# Install Homebrew packages
{{ range .packages.darwin.homebrew -}}
if command -v {{ . | quote }} >/dev/null 2>&1; then
  echo "{{ . }} already available; skipping brew install {{ . }}."
else
  brew install {{ . | quote }}
fi
{{ end -}}

# Install packages that use shell commands
{{ range $name, $install := .packages.darwin.shell_installs -}}
echo "Installing {{ $name }}..."
{{ $install.command }}
{{ end -}}

{{ end -}}

{{ if eq .chezmoi.os "linux" -}}

# Install host-level rpm-ostree packages on Fedora atomic/Silverblue systems.
# These are for compositor/session components that need host integration and
# are not good fits for Homebrew or Flatpak.
{{ if .packages.linux.rpm_ostree -}}
if command -v rpm-ostree >/dev/null 2>&1; then
  rpm_ostree_packages=(
{{ range .packages.linux.rpm_ostree -}}
    {{ . | quote }}
{{ end -}}
  )
  if [ "$(id -u)" -eq 0 ]; then
    rpm-ostree install --idempotent --allow-inactive "${rpm_ostree_packages[@]}"
  else
    sudo rpm-ostree install --idempotent --allow-inactive "${rpm_ostree_packages[@]}"
  fi
else
  echo "rpm-ostree not found; skipping Linux host rpm-ostree packages."
fi
{{ end -}}

# Linux uses Homebrew for CLI/dev tools across mutable and atomic distributions
# such as Ubuntu, Fedora Workstation, and Fedora Silverblue.
if ! command -v brew >/dev/null 2>&1; then
  if [ -x /home/linuxbrew/.linuxbrew/bin/brew ]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
  elif [ -x "$HOME/.linuxbrew/bin/brew" ]; then
    eval "$("$HOME/.linuxbrew/bin/brew" shellenv)"
  else
    echo "Homebrew is required for Linux package installation."
    echo "Install it from https://brew.sh/ and re-run chezmoi apply."
    exit 1
  fi
else
  eval "$(brew shellenv)"
fi

# Install Homebrew packages. Skip packages whose primary binary is already
# available, which helps when a base distro or toolbox already provides them.
# Entries without a `binary` (e.g. keg-only formulae like glibc, whose
# binaries shadow system runtime tools) are always passed to `brew install`,
# which is itself idempotent.
{{ range .packages.linux.homebrew -}}
{{- if hasKey . "binary" -}}
if command -v {{ .binary | quote }} >/dev/null 2>&1; then
  echo "{{ .binary }} already available; skipping brew install {{ .name }}."
else
  brew install {{ .name | quote }}
fi
{{- else -}}
brew install {{ .name | quote }}
{{- end }}
{{ end -}}

# Install Flatpak applications when Flatpak is available. Use the per-user
# installation explicitly so hosts with both system and user Flathub remotes do
# not prompt for an installation scope during unattended chezmoi apply.
if command -v flatpak >/dev/null 2>&1; then
  flatpak remote-add --user --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo
  flatpak remote-modify --user --enable flathub 2>/dev/null || true
{{ range .packages.linux.flatpak -}}
  flatpak install --user -y flathub {{ . | quote }}
{{ end -}}
else
  echo "flatpak not found; skipping Linux GUI/app Flatpaks."
fi

{{ end -}}

# Cross-platform shell-based installations

# npm global package installations
{{ if and (ne .chezmoi.os "android") .packages.npm_global -}}
# Install npm global packages
if command -v npm >/dev/null 2>&1; then
{{ range .packages.npm_global -}}
  if command -v {{ .binary | quote }} >/dev/null 2>&1; then
    echo "{{ .binary }} already available; skipping npm install -g {{ .package }}."
  else
{{- if hasKey . "version" }}
    npm install -g {{ .args }} {{ printf "%s@%s" .package .version | quote }}
{{- else }}
    npm install -g {{ .args }} {{ .package | quote }}
{{- end }}
  fi
{{ end -}}
else
  echo "npm not found; skipping npm global packages."
fi
{{ end -}}

# UV tool package installations
{{ if .packages.uv_tool -}}
# Install UV tool packages
{{ range .packages.uv_tool -}}
echo "Installing UV package {{ . }}..."
uv tool install {{ . }}
{{ end -}}
{{ end -}}

{{ if ne .chezmoi.os "android" -}}
gpg --import ~/.{{ .gpg_key }}.asc
gpg --command-fd=0 --pinentry-mode=loopback --edit-key {{ .gpg_key }} <<EOF
trust
5
y
save
EOF
{{ end -}}
