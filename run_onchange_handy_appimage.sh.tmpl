#!{{ lookPath "bash" }}

# Download/upgrade the Handy speech-to-text AppImage on Linux.
#
# Handy is a Tauri desktop app. Its Flatpak is not yet published to Flathub
# (upstream issue #1555), so on Fedora atomic hosts we use the upstream
# AppImage release instead of rpm-ostree layering the .rpm.
#
# Re-runs whenever .chezmoidata/packages.yaml's linux.handy block changes
# (chezmoi re-renders this template, so a version bump triggers re-download).

{{ if eq .chezmoi.os "linux" -}}
set -euo pipefail

VERSION="{{ .packages.linux.handy.version }}"
URL="{{ .packages.linux.handy.url }}"
DEST="$HOME/.local/bin/Handy.AppImage"
TMP="$DEST.new"

mkdir -p "$(dirname "$DEST")"

# Skip if the target version is already present.
EXISTING=""
if [ -x "$DEST" ]; then
  EXISTING="$(strings "$DEST" 2>/dev/null | grep -m1 -oE 'Handy [0-9]+\.[0-9]+\.[0-9]+' || true)"
fi
if [ -n "$EXISTING" ] && echo "$EXISTING" | grep -q "$VERSION"; then
  echo "Handy AppImage $VERSION already installed at $DEST; skipping."
  exit 0
fi

echo "Installing Handy AppImage $VERSION -> $DEST"
curl -sSL -o "$TMP" "$URL"
chmod +x "$TMP"
mv -f "$TMP" "$DEST"
echo "Installed $DEST"
{{ else -}}
echo "Handy AppImage install is Linux-only; skipping on {{ .chezmoi.os }}."
{{ end -}}
